# Python cache and bytecode
__pycache__/
*.py[cod]
*.py[cod].*

# Notebook cache
.ipynb_checkpoints/

# Raw source financial statements
data/financials/
data/raw/
data/source/
data/interim/

# Ignore generated presentation outputs and local runtime cache
outputs/.mplconfig/
outputs/figures/
outputs/reports/

# Keep tabular outputs tracked (used by downstream modules)
!outputs/tables/
